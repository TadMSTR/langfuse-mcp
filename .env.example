# Required
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Optional — default project filter (copy from Langfuse UI: Settings → Projects)
LANGFUSE_DEFAULT_PROJECT_ID=

# Logging
LOG_LEVEL=INFO
LOG_FILE=

# Optional telemetry (all off by default)
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_BUCKET=langfuse-mcp

OTEL_EXPORTER_OTLP_ENDPOINT=

NATS_URL=
NATS_SUBJECT_PREFIX=langfuse
